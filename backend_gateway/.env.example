# 复制为 .env 并填实际值
APP_NAME=TestMate Gateway
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

JWT_SECRET=please-change-me-32-bytes-random
JWT_EXPIRE_MINUTES=10080

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=testmate
MYSQL_PASSWORD=testmate
MYSQL_DATABASE=testmate

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

DIFY_BASE_URL=http://dify:80/v1
DIFY_API_KEY=app-xxxxx
DIFY_TIMEOUT_SECONDS=120

RAGFLOW_BASE_URL=http://ragflow:9380/api/v1
RAGFLOW_API_KEY=ragflow-xxxxx

DINGTALK_DEFAULT_WEBHOOK=
