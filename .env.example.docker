# TestMate docker 整栈配置(docker compose --env-file .env.docker)
# 复制为 .env.docker 后使用
# 容器间用 service name 通信:host=mysql / host=redis

# ===== MySQL(容器内 root + 应用账号) =====
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=testmate
MYSQL_USER=testmate
MYSQL_PASSWORD=testmate

# ===== Backend(docker compose 读这些注入到 backend 容器) =====
JWT_SECRET=docker-dev-secret-change-in-prod
DIFY_MOCK=true
DIFY_BASE_URL=http://dify:80/v1
DIFY_API_KEY=app-mock
RAGFLOW_BASE_URL=http://ragflow:9380/api/v1
RAGFLOW_API_KEY=ragflow-mock

# ===== Admin 默认密码 =====
ADMIN_DEFAULT_PASSWORD=TestMate@2026
