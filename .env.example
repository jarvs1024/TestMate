# TestMate 通用 .env 模板(被 pydantic-settings 加载)
# 实际部署请根据场景选:
#   - 本地直跑:用 .env.example.local 复制
#   - docker 整栈:用 .env.example.docker 复制
# 本文件仅作字段参考

APP_NAME=TestMate Gateway
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

JWT_SECRET=please-change-me-32-bytes-random
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=testmate
MYSQL_PASSWORD=testmate
MYSQL_DATABASE=testmate

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

DIFY_MOCK=false
DIFY_BASE_URL=http://dify:80/v1
DIFY_API_KEY=app-xxxxx
DIFY_TIMEOUT_SECONDS=120

RAGFLOW_BASE_URL=http://ragflow:9380/api/v1
RAGFLOW_API_KEY=ragflow-xxxxx

DINGTALK_DEFAULT_WEBHOOK=
