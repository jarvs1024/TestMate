# TestMate 本地直跑配置(后端/前端在 host 上跑,只把 MySQL/Redis 放 docker)
# 复制为 .env.local 后使用

# ===== 服务 =====
APP_NAME=TestMate Gateway
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# ===== JWT(本地开发用默认值,生产必须改) =====
JWT_SECRET=dev-secret-please-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ===== MySQL(本地:连 docker 暴露的 3306) =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=testmate
MYSQL_PASSWORD=testmate
MYSQL_DATABASE=testmate

# ===== Redis(本地:连 docker 暴露的 6379) =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ===== Dify(本地开发默认开 mock,不依赖外部) =====
DIFY_MOCK=true
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=mock-key
DIFY_TIMEOUT_SECONDS=120

# ===== RAGFlow(本地暂未启,留占位) =====
RAGFLOW_BASE_URL=http://localhost:9380/api/v1
RAGFLOW_API_KEY=ragflow-mock

# ===== DingTalk(本地留空) =====
DINGTALK_DEFAULT_WEBHOOK=

# ===== Admin 默认密码(给 create_admin.py 用) =====
ADMIN_DEFAULT_PASSWORD=Admin@123
