# TestMate Linux 部署环境模板
# 用法:
#   cp deploy/.env.template deploy/.env
#   $EDITOR deploy/.env            # 至少改 JWT_SECRET / MYSQL_ROOT_PASSWORD / ADMIN_DEFAULT_PASSWORD
#
# 注意:容器间用 service name 通信(host=mysql / host=redis)
#      从浏览器/客户端访问才用 localhost 或 服务器 IP。

# ============== 部署基础 ==============
PROJECT_ROOT=/opt/testmate
DATA_ROOT=/opt/testmate/data

# ============== MySQL ==============
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=testmate
MYSQL_USER=testmate
MYSQL_PASSWORD=change-me-testmate
MYSQL_HOST_PORT=43060

# ============== Redis ==============
REDIS_HOST_PORT=63790

# ============== Backend ==============
JWT_SECRET=please-generate-with-openssl-rand-base64-32
JWT_EXPIRE_MINUTES=10080

# ============== Frontend ==============
FRONTEND_HOST_PORT=8080
BACKEND_HOST_PORT=18000
BACKEND_INTERNAL_URL=http://backend:8000

# ============== 钉钉 ==============
DINGTALK_DEFAULT_WEBHOOK=

# ============== Admin ==============
ADMIN_DEFAULT_PASSWORD=Admin@123

# ============== 资源限制(按机器调) ==============
BACKEND_CPU_LIMIT=2.0
BACKEND_MEM_LIMIT=2g
FRONTEND_CPU_LIMIT=0.5
FRONTEND_MEM_LIMIT=256m
MYSQL_CPU_LIMIT=2.0
MYSQL_MEM_LIMIT=2g
REDIS_CPU_LIMIT=0.5
REDIS_MEM_LIMIT=512m
